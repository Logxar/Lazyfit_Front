{
    "name": "Lazyfit Frontend Development Container",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "remoteUser": "vscode",
    "mounts": [
        "type=bind,source=${localWorkspaceFolder}/../Lazyfit,target=/workspaces/Lazyfit,readonly"
    ],
    "workspaceFolder": "/workspaces/Lazyfit_Front",
    "forwardPorts": [3000, 8080],
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh"
            },
            "extensions": [
                "Dart-Code.dart-code",
                "Dart-Code.flutter",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker"
            ]
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {}
    }
}
